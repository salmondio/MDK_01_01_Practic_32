<UserControl x:Class="WpfApp1.Elements.Record"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WpfApp1.Elements"
             mc:Ignorable="d" 
             d:DesignHeight="100" d:DesignWidth="400">
    <Grid Background="#eeeef2">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="100"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="tDescription" Grid.Row="1" TextWrapping="Wrap" Text="TextBlock" VerticalAlignment="top" Grid.ColumnSpan="2" Height="34" Margin="10,20,10,0" Background="White" FontSize="9"/>
        <TextBox x:Name="tState" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Margin="10,20,13,0" FontSize="9" BorderBrush="White"/>
        <TextBox x:Name="tName" Grid.Column="1" Margin="13,20,10,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" FontSize="9" BorderBrush="White"/>
        <Button Click="Change" Grid.Column="2" Content="Изменить" HorizontalAlignment="Right" VerticalAlignment="Top" Height="30" Width="80" Margin="0,10,10,0" BorderBrush="Yellow" Background="Yellow"/>
        <Button Click="Delete" Grid.Column="2" Content="Удалить" HorizontalAlignment="Right" Grid.Row="1" VerticalAlignment="top" Height="30" Width="80" Margin="0, 10, 10, 0" BorderBrush="red" Background="Red" Foreground="white"/>
        <Label Content="Состояние:" Margin="10,0,13,0" VerticalAlignment="Top" Height="20" FontSize="9"/>
        <Label Content="Наименование:" Margin="13,0,10,0" VerticalAlignment="Top" Height="20" FontSize="9" Grid.Column="1"/>
        <Label Content="Описание:" VerticalAlignment="Top" Height="20" FontSize="9" Grid.Row="1" Grid.ColumnSpan="2" Margin="10,0,10,0"/>

    </Grid>
</UserControl>
