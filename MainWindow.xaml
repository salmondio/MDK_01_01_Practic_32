<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Menu>
            
            <MenuItem Header="Пластинки">
                <MenuItem Header="Список" Click="AllRecords"/>
                <MenuItem Header="Добавить" Click="AddRecord"/>
                <MenuItem Header="Експортировать" Click="ExportRecord"/>
            </MenuItem>
            <MenuItem Header="Поставщики">
                <MenuItem Header="Список" Click="AllManufactures"/>
                <MenuItem Header="Добавить" Click="AddManufacture"/>
            </MenuItem>
            <MenuItem Header="Поставки">
                <MenuItem Header="Список" Click="AllSupples"/>
                <MenuItem Header="Добавить" Click="AddSupple"/>
            </MenuItem>
            <MenuItem Header="Состояния">
                <MenuItem Header="Список" Click="AllStates"/>
                <MenuItem Header="Добавить" Click="AddState"/>
            </MenuItem>
        </Menu>

        <Frame x:Name="frame" NavigationUIVisibility="Hidden" Margin="0, 25, 0, 0"/>
    </Grid>
</Window>
