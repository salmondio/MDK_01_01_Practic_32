<Page x:Class="WpfApp1.Pages.Records.Add"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp1.Pages.Records"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Add">

    <Grid Background="#FFE6E6E6">
        <!-- Элемент Border за счёт него создаётся скругление и тень -->
        <Border BorderBrush="#FFFAFAFA"
                Margin="20,20,20,20"
                BorderThickness="1"
                Background="#FFFAFAFA"
                CornerRadius="20">
            <!-- Тень -->
            <Border.Effect>
                <DropShadowEffect BlurRadius="10"
                                  Color="Black"
                                  Direction="315"
                                  ShadowDepth="5"
                                  Opacity="0.5"/>
            </Border.Effect>

            <!-- Контейнер для данных -->
            <Grid Margin="15">
                <!-- Изображение -->
                <Image Width="68"
                       Height="68"
                       VerticalAlignment="Top"
                       HorizontalAlignment="Left"
                       Source="/Image/ic_VinilRecord.png"/>

                <!-- Контейнер для данных -->
                <Grid Margin="73,0,0,0">
                    <!-- Столбцы 50% 50% -->
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Текст -->
                    <Label Content="Название пластинки:"
                           Margin="0,0,10,0"
                           VerticalAlignment="Top"/>

                    <!-- Поле для ввода данных -->
                    <TextBox x:Name="tbName"
                             Margin="0,26,10,0"
                             Height="50"
                             TextWrapping="Wrap"
                             Text=""
                             VerticalContentAlignment="Center"
                             VerticalAlignment="Top"
                             Padding="10, 0">
                        <!-- Тень -->
                        <TextBox.Effect>
                            <DropShadowEffect BlurRadius="10"
                                              Color="Black"
                                              Direction="315"
                                              ShadowDepth="2"
                                              Opacity="0.5"/>
                        </TextBox.Effect>
                    </TextBox>

                    <!-- Текст -->
                    <Label Content="Формат записи:"
                           Margin="0,77,10,0"
                           VerticalAlignment="Top"/>

                    <!-- Выпадающий список формата записи -->
                    <ComboBox x:Name="tbFormat"
                              Margin="0,103,10,0"
                              Height="25"
                              VerticalAlignment="Top"
                              SelectedIndex="0">
                        <!-- Тень -->
                        <ComboBox.Effect>
                            <DropShadowEffect BlurRadius="10"
                                              Color="Black"
                                              Direction="315"
                                              ShadowDepth="2"
                                              Opacity="0.5"/>
                        </ComboBox.Effect>
                        <!-- Данные -->
                        <TextBlock>Моно</TextBlock>
                        <TextBlock>Стерео</TextBlock>
                    </ComboBox>

                    <!-- Текст -->
                    <Label Content="Производитель:"
                           Margin="0,128,10,0"
                           VerticalAlignment="Top"/>

                    <!-- Выпадающий список производителя -->
                    <ComboBox x:Name="tbManufacturer"
                              Margin="0,154,10,0"
                              Height="25"
                              VerticalAlignment="Top">
                        <!-- Тень -->
                        <ComboBox.Effect>
                            <DropShadowEffect BlurRadius="10"
                                              Color="Black"
                                              Direction="315"
                                              ShadowDepth="2"
                                              Opacity="0.5"/>
                        </ComboBox.Effect>
                    </ComboBox>

                    <!-- Текст (колонка 2) -->
                    <Label Content="Год выпуска:"
                           Margin="10,0,10,0"
                           VerticalAlignment="Top"
                           Grid.Column="1"/>

                    <!-- Поле для ввода данных (колонка 2) -->
                    <TextBox x:Name="tbYear"
                             Margin="10,26,10,0"
                             Height="25"
                             TextWrapping="Wrap"
                             Text=""
                             VerticalContentAlignment="Center"
                             VerticalAlignment="Top"
                             Padding="10, 0"
                             Grid.Column="1"
                             PreviewTextInput="tbPreviewNumber">
                        <!-- Тень -->
                        <TextBox.Effect>
                            <DropShadowEffect BlurRadius="10"
                                              Color="Black"
                                              Direction="315"
                                              ShadowDepth="2"
                                              Opacity="0.5"/>
                        </TextBox.Effect>
                    </TextBox>

                    <!-- Текст (колонка 2) -->
                    <Label Content="Размер:"
                           Margin="10,51,10,0"
                           VerticalAlignment="Top"
                           Grid.Column="1"/>

                    <!-- Выпадающий список размера (колонка 2) -->
                    <ComboBox x:Name="tbSize"
                              Margin="10,77,10,0"
                              Height="25"
                              Grid.Column="1"
                              VerticalAlignment="Top"
                              SelectedIndex="0">
                        <!-- Тень -->
                        <ComboBox.Effect>
                            <DropShadowEffect BlurRadius="10"
                                              Color="Black"
                                              Direction="315"
                                              ShadowDepth="2"
                                              Opacity="0.5"/>
                        </ComboBox.Effect>
                        <!-- Данные -->
                        <TextBlock>7 дюймов</TextBlock>
                        <TextBlock>10 дюймов</TextBlock>
                        <TextBlock>12 дюймов</TextBlock>
                        <TextBlock>Иное</TextBlock>
                    </ComboBox>

                    <!-- Текст (колонка 2) -->
                    <Label Content="Стоимость:"
                           Margin="10,103,10,0"
                           VerticalAlignment="Top"
                           Grid.Column="1"/>

                    <!-- Поле для ввода данных (колонка 2) -->
                    <TextBox x:Name="tbPrice"
                             Margin="10,128,10,0"
                             Height="25"
                             TextWrapping="Wrap"
                             Text=""
                             VerticalContentAlignment="Center"
                             VerticalAlignment="Top"
                             Padding="10, 0"
                             Grid.Column="1"
                             PreviewTextInput="tbPreviewFloat">
                        <!-- Тень -->
                        <TextBox.Effect>
                            <DropShadowEffect BlurRadius="10"
                                              Color="Black"
                                              Direction="315"
                                              ShadowDepth="2"
                                              Opacity="0.5"/>
                        </TextBox.Effect>
                    </TextBox>

                    <!-- Текст (колонка 2) -->
                    <Label Content="Состояние:"
                           Margin="10,154,10,0"
                           VerticalAlignment="Top"
                           Grid.Column="1"/>

                    <!-- Выпадающий список состояния (колонка 2) -->
                    <ComboBox x:Name="tbState"
                          Margin="10,180,10,0"
                          Height="25"
                          VerticalAlignment="Top"
                          Grid.Column="1">
                        <!-- Тень -->
                        <ComboBox.Effect>
                            <DropShadowEffect BlurRadius="10"
                          Color="Black"
                          Direction="315"
                          ShadowDepth="2"
                          Opacity="0.5"/>
                        </ComboBox.Effect>
                    </ComboBox>

                    <!-- Текст -->
                    <Label Content="Заметки:"
                       Margin="0,184,194,0"
                       VerticalAlignment="Top"/>

                    <!-- Поле для ввода данных -->
                    <TextBox x:Name="tbDescription"
                         Margin="0,210,10,40"
                         TextWrapping="Wrap"
                         Text=""
                         Padding="10, 10"
                         Grid.ColumnSpan="3">
                        <!-- Тень -->
                        <TextBox.Effect>
                            <DropShadowEffect BlurRadius="10"
                          Color="Black"
                          Direction="315"
                          ShadowDepth="2"
                          Opacity="0.5"/>
                        </TextBox.Effect>
                    </TextBox>

                    <!-- Кнопка -->
                    <Button x:Name="addBth"
                        Content="Добавить"
                        HorizontalAlignment="Right"
                        Margin="0,0,10,10"
                        VerticalAlignment="Bottom"
                        Width="100"
                        Grid.Column="2"
                        Height="25"
                        BorderBrush="#FFFF9800"
                        Background="#FFFF9800"
                        Foreground="White"
                        FontWeight="Bold"
                        Click="AddRecord">
                        <!-- Тень -->
                        <Button.Effect>
                            <DropShadowEffect BlurRadius="10"
                          Color="Black"
                          Direction="315"
                          ShadowDepth="2"
                          Opacity="0.5"/>
                        </Button.Effect>
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>