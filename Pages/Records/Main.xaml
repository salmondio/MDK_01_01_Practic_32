<Page x:Class="WpfApp1.Pages.Records.Main"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp1.Pages.Records"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Main">

    <Grid Background="#FFE6E6E6">
        <!-- Контейнер для фильтра -->
        <Grid Height="60" VerticalAlignment="Top">
            <!-- Столбцы 50% 25% 25% -->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50*"/>
                <ColumnDefinition Width="25*"/>
                <ColumnDefinition Width="25*"/>
            </Grid.ColumnDefinitions>

            <!-- Текст -->
            <Label
                Content="Поиск:"
                Margin="10,0,10,0"
                VerticalAlignment="Top"/>

            <!-- Поле для ввода -->
            <TextBox
                x:Name="tbName"
                Margin="10,30,10,0"
                Height="25"
                TextWrapping="Wrap"
                Text=""
                VerticalContentAlignment="Center"
                VerticalAlignment="Top"
                Padding="10, 0"
                KeyUp="SearchRecords">
                <!-- Тень -->
                <TextBox.Effect>
                    <DropShadowEffect
                        BlurRadius="10"
                        Color="Black"
                        Direction="315"
                        ShadowDepth="2"
                        Opacity="0.5"/>
                </TextBox.Effect>
            </TextBox>

            <!-- Текст -->
            <Label
                Content="Поставщик:"
                Margin="10,4,10,0"
                VerticalAlignment="Top"
                Grid.Column="1"/>

            <!-- Выпадающий список поставщиков -->
            <ComboBox
                x:Name="tbManufacturer"
                Margin="10,30,10,0"
                Height="25"
                VerticalAlignment="Top"
                Grid.Column="1"
                SelectionChanged="FilterRecords">
                <!-- Тень -->
                <ComboBox.Effect>
                    <DropShadowEffect
                        BlurRadius="10"
                        Color="Black"
                        Direction="315"
                        ShadowDepth="2"
                        Opacity="0.5"/>
                </ComboBox.Effect>
            </ComboBox>

            <!-- Текст -->
            <Label
                Content="Состояние:"
                Margin="10,4,10,0"
                VerticalAlignment="Top"
                Grid.Column="2"/>

            <!-- Выпадающий список состояний -->
            <ComboBox
                x:Name="tbState"
                Margin="10,30,10,0"
                Height="25"
                VerticalAlignment="Top"
                Grid.Column="2"
                SelectedIndex="9"
                SelectionChanged="FilterRecords">
                <!-- Тень -->
                <ComboBox.Effect>
                    <DropShadowEffect
                        BlurRadius="10"
                        Color="Black"
                        Direction="315"
                        ShadowDepth="2"
                        Opacity="0.5"/>
                </ComboBox.Effect>
            </ComboBox>
        </Grid>

        <!-- Элемент ScrollViewer Позволяет прокручивать список элементов -->
        <ScrollViewer Margin="10,65,10,10">
            <!-- Элемент StackPanel Позволяет создавать списки в вертикальном порядке -->
            <StackPanel
                x:Name="recordsParent"
                Margin="10">
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
