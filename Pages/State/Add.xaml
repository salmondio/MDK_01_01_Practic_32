<Page x:Class="WpfApp1.Pages.State.Add"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp1.Pages.State"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Add">

    <Grid Background="#FFe6e6e6">
        <Border BorderBrush="#FFFFFAFA" Margin="20,20,20,20" BorderThickness="1" Background="#FFFFFAFA" CornerRadius="20">
            <!-- Тень -->
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" Color="Black" Direction="315" ShadowDepth="5" Opacity="0.5"/>
            </Border.Effect>
            <!-- Контейнер для данных -->
            <Grid Margin="15">
                <!-- Изображение -->
                <Image Width="68" Height="68" VerticalAlignment="Top" HorizontalAlignment="Left" 
                       Source="/VinyiRecordsApplication;component/Image/ic_State.png"/>
                <!-- Контейнер для данных -->
                <Grid Margin="73,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Текст -->
                    <Label Content="#Наименование состояния:" Margin="0,0,10.2,0" VerticalAlignment="Top"/>
                    <!-- Поле для ввода данных -->
                    <TextBox x:Name="tbName" Margin="0,26,10.2,0" Height="25" TextWrapping="Wrap" Text="" 
                             VerticalContentAlignment="Center" VerticalAlignment="Top" Padding="10,0" Grid.Column="0">
                        <!-- Тень -->
                        <TextBox.Effect>
                            <DropShadowEffect BlurRadius="10" Color="Black" Direction="315" ShadowDepth="2" Opacity="0.5"/>
                        </TextBox.Effect>
                    </TextBox>

                    <!-- Текст -->
                    <Label Content="#Описание:" Margin="0,51,10,0" VerticalAlignment="Top" Grid.ColumnSpan="2"/>
                    <!-- Поле для ввода данных -->
                    <TextBox x:Name="tbDescription" Margin="0,77,10.2,39.6" TextWrapping="Wrap" Text="" 
                             Padding="10,10" Grid.ColumnSpan="2">
                        <!-- Тень -->
                        <TextBox.Effect>
                            <DropShadowEffect BlurRadius="10" Color="Black" Direction="315" ShadowDepth="2" Opacity="0.5"/>
                        </TextBox.Effect>
                    </TextBox>

                    <!-- Текст -->
                    <Label Content="#Сокращенное наименование:" Margin="10,0,9.8,0" VerticalAlignment="Top" Grid.Column="1"/>
                    <TextBox x:Name="tbSubname" Margin="10,25,9.8,0" Height="25" TextWrapping="Wrap" Text="" 
                             VerticalContentAlignment="Center" VerticalAlignment="Top" Padding="10,0" Grid.Column="1">
                        <!-- Тень -->
                        <TextBox.Effect>
                            <DropShadowEffect BlurRadius="10" Color="Black" Direction="315" ShadowDepth="2" Opacity="0.5"/>
                        </TextBox.Effect>
                    </TextBox>

                    <Button x:Name="addBtn" Content="#Добавить" HorizontalAlignment="Right" Margin="0,0,10,10" 
                            VerticalAlignment="Bottom" Width="100" Grid.Column="2" Height="25" 
                            BorderBrush="#FFFF8000" Background="#FFFF8000" Foreground="White" 
                            FontWeight="Bold" Click="AddState">
                        <Button.Effect>
                            <DropShadowEffect BlurRadius="10" Color="Black" Direction="315" ShadowDepth="2" Opacity="0.5"/>
                        </Button.Effect>
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>
