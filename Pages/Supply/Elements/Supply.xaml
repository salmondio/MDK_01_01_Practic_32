<UserControl x:Class="WpfApp1.Pages.Supply.Elements.Supply"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WpfApp1.Pages.Supply.Elements"
             mc:Ignorable="d">
    <Grid>
        <!-- Элемент Border за счёт него создаётся скругление и тень -->
        <Border 
            BorderBrush="#FFFAFAFA" 
            Margin="0,0,0,20" 
            BorderThickness="1" 
            Background="#FFFAFAFA" 
            CornerRadius="20" 
            VerticalAlignment="Top" 
            Height="160">

            <!-- Тень -->
            <Border.Effect>
                <DropShadowEffect 
                    BlurRadius="10" 
                    Color="Black" 
                    Direction="315" 
                    ShadowDepth="5" 
                    Opacity="0.5"/>
            </Border.Effect>

            <!-- Контейнер для данных -->
            <Grid Margin="15">
                <!-- Изображение -->
                <Image 
                    Width="68" 
                    Height="68" 
                    VerticalAlignment="Top" 
                    HorizontalAlignment="Left" 
                    Source="/Image/ic_supply.png"/>

                <!-- Кнопка «Изменить» -->
                <Button 
                    Content="Изменить" 
                    HorizontalAlignment="Left" 
                    VerticalAlignment="Top" 
                    Width="68" 
                    Height="25"
                    BorderBrush="#FFFF9800" 
                    Background="#FFFF9800" 
                    Foreground="White" 
                    FontWeight="Bold" 
                    Margin="0,73,0,0"
                    Click="EditSupply">
                    <!-- Тень -->
                    <Button.Effect>
                        <DropShadowEffect 
                            BlurRadius="10" 
                            Color="Black" 
                            Direction="315" 
                            ShadowDepth="2" 
                            Opacity="0.5"/>
                    </Button.Effect>
                </Button>

                <!-- Кнопка «Удалить» -->
                <Button 
                    Content="Удалить" 
                    HorizontalAlignment="Left" 
                    VerticalAlignment="Top" 
                    Width="68"
                    Height="25" 
                    BorderBrush="Red" 
                    Background="Red" 
                    Foreground="White" 
                    FontWeight="Bold"
                    Margin="0,103,0,0" 
                    Click="DeleteSupply">
                    <!-- Тень -->
                    <Button.Effect>
                        <DropShadowEffect 
                            BlurRadius="10" 
                            Color="Black" 
                            Direction="315" 
                            ShadowDepth="2" 
                            Opacity="0.5"/>
                    </Button.Effect>
                </Button>

                <!-- Контейнер для данных -->
                <Grid Margin="73,0,0,0">
                    <!-- Столбцы для разделения -->
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50*"/>
                        <ColumnDefinition Width="50*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Текст -->
                    <Label 
                        Content="Наименование поставщика:" 
                        Margin="0,0,10,0" 
                        VerticalAlignment="Top"/>

                    <!-- Поле для ввода данных -->
                    <TextBox 
                        x:Name="tbManufacturer" 
                        IsEnabled="False" 
                        Margin="0,26,10,0" 
                        Height="50" 
                        TextWrapping="Wrap" 
                        Text=""
                        VerticalContentAlignment="Center" 
                        VerticalAlignment="Top" 
                        Padding="10, 0">
                        <!-- Тень -->
                        <TextBox.Effect>
                            <DropShadowEffect 
                                BlurRadius="10" 
                                Color="Black" 
                                Direction="315" 
                                ShadowDepth="2" 
                                Opacity="0.5"/>
                        </TextBox.Effect>
                    </TextBox>

                    <!-- Текст -->
                    <Label 
                        Content="Дата поставки:" 
                        Margin="0,77,10,0" 
                        VerticalAlignment="Top"/>

                    <!-- Поле для ввода данных -->
                    <TextBox 
                        x:Name="tbDateDelivery" 
                        IsEnabled="False" 
                        Margin="0,103,10,0" 
                        Height="25" 
                        TextWrapping="Wrap"
                        Text="" 
                        VerticalContentAlignment="Center" 
                        VerticalAlignment="Top" 
                        Padding="10, 0">
                        <!-- Тень -->
                        <TextBox.Effect>
                            <DropShadowEffect 
                                BlurRadius="10" 
                                Color="Black" 
                                Direction="315" 
                                ShadowDepth="2" 
                                Opacity="0.5"/>
                        </TextBox.Effect>
                    </TextBox>

                    <!-- Текст (колонка 2) -->
                    <Label 
                        Content="Наименование пластинки:" 
                        Margin="10,0,10,0" 
                        VerticalAlignment="Top" 
                        Grid.Column="1"/>

                    <!-- Поле для ввода данных (колонка 2) -->
                    <TextBox 
                        x:Name="tbRecord" 
                        IsEnabled="False" 
                        Margin="10,26,10,0" 
                        Height="46" 
                        TextWrapping="Wrap" 
                        Text=""
                        VerticalContentAlignment="Center" 
                        VerticalAlignment="Top" 
                        Padding="10, 0" 
                        Grid.Column="1">
                        <!-- Тень -->
                        <TextBox.Effect>
                            <DropShadowEffect 
                                BlurRadius="10" 
                                Color="Black" 
                                Direction="315" 
                                ShadowDepth="2" 
                                Opacity="0.5"/>
                        </TextBox.Effect>
                    </TextBox>

                    <!-- Текст (колонка 2) -->
                    <Label 
                        Content="Количество поставки:" 
                        Margin="10,77,10,0" 
                        VerticalAlignment="Top" 
                        Grid.Column="1"/>

                    <!-- Поле для ввода данных (колонка 2) -->
                    <TextBox 
                        x:Name="tbCount" 
                        IsEnabled="False" 
                        Margin="10,103,10,0" 
                        Height="25" 
                        TextWrapping="Wrap" 
                        Text=""
                        VerticalContentAlignment="Center" 
                        VerticalAlignment="Top" 
                        Padding="10, 0" 
                        Grid.Column="1">
                        <!-- Тень -->
                        <TextBox.Effect>
                            <DropShadowEffect 
                                BlurRadius="10" 
                                Color="Black" 
                                Direction="315" 
                                ShadowDepth="2" 
                                Opacity="0.5"/>
                        </TextBox.Effect>
                    </TextBox>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
